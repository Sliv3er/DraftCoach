{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "paths": {
      "shared/*": [
        "../../shared/*"
      ]
    },
    "baseUrl": "."
  },
  "include": [
    "src/**/*.ts",
    "../../shared/engine/**/*.ts"
  ],
  "exclude": [
    "../../shared/__tests__"
  ]
}