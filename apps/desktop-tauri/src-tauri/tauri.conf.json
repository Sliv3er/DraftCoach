{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DraftCoach",
  "version": "1.1.0",
  "identifier": "com.draftcoach.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DraftCoach",
        "width": 1920,
        "height": 1080,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "visible": false,
        "decorations": false,
        "transparent": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../sidecar/*": "sidecar/",
      "../../desktop/src/main/*.cjs": "backend/",
      "../../desktop/src/main/cooldowns/*.cjs": "backend/cooldowns/",
      "../../../shared/kb/data/*": "kb-data/",
      "../../../assets/icon.png": "icon.png"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false
      }
    },
    "externalBin": []
  },
  "plugins": {}
}
